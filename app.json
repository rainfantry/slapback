{
  "expo": {
    "name": "Slapback",
    "slug": "slapback",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E0E10"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rainfantry.slapback",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Slapback plays your voice back with a short delay so you can monitor your singing."
      }
    },
    "android": {
      "package": "com.rainfantry.slapback",
      "adaptiveIcon": {
        "backgroundColor": "#0E0E10",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      [
        "react-native-audio-api",
        {
          "iosMicrophonePermission": "Slapback plays your voice back with a short delay so you can monitor your singing.",
          "androidPermissions": [
            "android.permission.RECORD_AUDIO",
            "android.permission.MODIFY_AUDIO_SETTINGS"
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "4b376a6d-391b-474e-bf2c-eae5b556d568"
      }
    }
  }
}
